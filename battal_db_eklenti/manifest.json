{
  "manifest_version": 3,
  "name": "BATTAL · Defter Beyan + Uyumsoft Kontrol",
  "version": "3.1",
  "description": "Defter Beyan + Uyumsoft tam otomasyon: gelen fatura XML detay cekme, otomatik gider siniflandirma (SINIF_KURALLAR), capraz kontrol, eksik giderleri otomatik gonderme, alici bilgi kontrolu.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.defterbeyan.gov.tr/*",
    "https://*.uyum.com.tr/*",
    "https://*.uyumsoft.com.tr/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://portal.defterbeyan.gov.tr/*",
        "https://edonusum.uyum.com.tr/*",
        "https://portal.uyumsoft.com.tr/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "https://portal.defterbeyan.gov.tr/*",
        "https://edonusum.uyum.com.tr/*"
      ]
    }
  ]
}
